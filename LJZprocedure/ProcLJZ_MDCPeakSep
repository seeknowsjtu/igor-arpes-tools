    LJZ_MDCPeakSep_ShowCurrentWave()
    return 0
End

Function LJZ_MDCPeakSep_SelectRow(row, forceNoConfirm)
    Variable row, forceNoConfirm

    if (!forceNoConfirm)
        if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
            LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
            return -1
        endif
    endif

    String listStr = LJZ_MDCPeakSep_CurrentWaveList()
    Variable n = ItemsInList(listStr, ";")
    if (n <= 0)
        SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
        NVAR SelRow = $(LJZ_MDCPeakSep_BaseDF() + ":SelRow")
        sWave = ""
        SelRow = -1
        LJZ_MDCPeakSep_ClearWindowGlobals()
        LJZ_MDCPeakSep_ClearCurrentResultDisplay()
        LJZ_MDCPeakSep_RefreshWindowControls()
        LJZ_MDCPeakSep_RefreshResultControls()
        LJZ_MDCPeakSep_ShowCurrentWave()
        LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
        return -1
    endif

    if (row < 0 || row >= n)
        LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
        return -1
    endif

    LJZ_MDCPeakSep_SelectWaveRow(row)
    if (LJZ_MDCPeakSep_LoadStoredResultForSelection() != 0)
        LJZ_MDCPeakSep_ClearCurrentResultDisplay()
        LJZ_MDCPeakSep_AutoFillWindows()
    endif
    LJZ_MDCPeakSep_MarkDirty(0)

    LJZ_MDCPeakSep_RefreshWindowControls()
    LJZ_MDCPeakSep_RefreshResultControls()
    LJZ_MDCPeakSep_ShowCurrentWave()
    LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
    return 0
End

Function LJZ_MDCPeakSep_MeasureAndNext()
    LJZ_MDCPeakSep_EnsureDF()

    Variable ret = LJZ_MDCPeakSep_FindPeakSep()
    String listStr = LJZ_MDCPeakSep_CurrentWaveList()
    Variable n = ItemsInList(listStr, ";")
    NVAR SelRow = $(LJZ_MDCPeakSep_BaseDF() + ":SelRow")

    if (ret == 0 && n > 0)
        if (SelRow < n - 1)
            LJZ_MDCPeakSep_MarkDirty(0)
            LJZ_MDCPeakSep_SelectWaveRow(SelRow + 1)
            LJZ_MDCPeakSep_RefreshCurrentSelection()
            LJZ_MDCPeakSep_RefreshTitleBoxes()
        endif
    endif

    return 0
End

