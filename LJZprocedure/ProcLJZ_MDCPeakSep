Function LJZ_MDCPeakSep_LoadSavedResultForCurrentWave()
    String base = LJZ_MDCPeakSep_BaseDF()
    LJZ_MDCPeakSep_ClearCurrentMeasure()

    SVAR/Z sWaveSel = $(base + ":WaveSel")
    if (!SVAR_Exists(sWaveSel) || strlen(sWaveSel) == 0)
        return 0
    endif

    String nm = NameOfWave($sWaveSel)
    Variable idx = LJZ_MDCPeakSep_ParseWaveIndex(nm)
    if (numtype(idx) != 0 || idx < 0)
        return 0
    endif

    String sourceDF = GetWavesDataFolder($sWaveSel, 1)
    Wave/Z wL = $(sourceDF + "mdc_xleft")
    Wave/Z wR = $(sourceDF + "mdc_xright")
    Wave/Z wS = $(sourceDF + "mdc_sep")
    if (!WaveExists(wL) || !WaveExists(wR) || !WaveExists(wS))
        return 0
    endif
    if (idx >= numpnts(wL) || idx >= numpnts(wR) || idx >= numpnts(wS))
        return 0
    endif

    NVAR/Z XLeft = $(base + ":XLeft")
    NVAR/Z XRight = $(base + ":XRight")
    NVAR/Z Sep = $(base + ":Sep")
    if (!NVAR_Exists(XLeft) || !NVAR_Exists(XRight) || !NVAR_Exists(Sep))
        return 0
    endif

    XLeft = wL[idx]
    XRight = wR[idx]
    Sep = wS[idx]
    if (numtype(XLeft) != 0 || numtype(XRight) != 0 || numtype(Sep) != 0)
        LJZ_MDCPeakSep_ClearCurrentMeasure()
        return 0
    endif
    return 1
End

Function LJZ_MDCPeakSep_SelectRow(row, forceNoConfirm)
    Variable row, forceNoConfirm

    if (!forceNoConfirm)
        if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
            LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
            return -1
        endif
    endif

    String base = LJZ_MDCPeakSep_BaseDF()
    SVAR/Z sSourceDF = $(base + ":SourceDF")
    SVAR/Z sWaveSel = $(base + ":WaveSel")
    NVAR/Z SelRow = $(base + ":SelRow")
    Wave/Z wSel = $(base + ":LB_Sel")
    NVAR/Z XLeft = $(base + ":XLeft")
    NVAR/Z XRight = $(base + ":XRight")
    NVAR/Z Sep = $(base + ":Sep")
    if (!SVAR_Exists(sSourceDF) || !SVAR_Exists(sWaveSel) || !NVAR_Exists(SelRow) || !WaveExists(wSel) || !NVAR_Exists(XLeft) || !NVAR_Exists(XRight) || !NVAR_Exists(Sep))
        LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
        return -1
    endif

    String wl = LJZ_MDCPeakSep_ListMDCShowWaves_OneDF(sSourceDF)
    Variable n = ItemsInList(wl, ";")
    if (row < 0 || row >= n)
        LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
        return -1
    endif

    SelRow = row
    wSel = 0
    wSel[row] = 1
    sWaveSel = StringFromList(row, wl, ";")

    if (!LJZ_MDCPeakSep_LoadSavedResultForCurrentWave())
        LJZ_MDCPeakSep_AutoFillWindows()
        if (!LJZ_MDCPeakSep_HasValidCurrentResultGlobals())
            LJZ_MDCPeakSep_ClearCurrentMeasure()
        endif
    endif
    LJZ_MDCPeakSep_MarkDirty(0)

    LJZ_MDCPeakSep_RefreshWindowControls()
    LJZ_MDCPeakSep_RefreshResultControls()
    LJZ_MDCPeakSep_RefreshGraph()
    LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
    return 0
End

Function LJZ_MDCPeakSep_PlotResult()
    String base = LJZ_MDCPeakSep_BaseDF()
    SVAR/Z sSourceDF = $(base + ":SourceDF")
    if (!SVAR_Exists(sSourceDF))
        DoAlert 0, "Source DF is unavailable."
        return -1
    endif
    String dfc = LJZ_MDCPeakSep_df_with_colon(sSourceDF)

    Wave/Z wL = $(dfc + "mdc_xleft")
    Wave/Z wR = $(dfc + "mdc_xright")
    Wave/Z wS = $(dfc + "mdc_sep")
    if (!WaveExists(wL) || !WaveExists(wR) || !WaveExists(wS))
        DoAlert 0, "Result waves not found. Please measure first."
        return -1
    endif

    DoWindow/K MDCPeakSep_ResultGraph
    Display/N=MDCPeakSep_ResultGraph wS
    AppendToGraph/R wL, wR
    ModifyGraph rgb(mdc_sep)=(0,0,0), rgb(mdc_xleft)=(0,0,65535), rgb(mdc_xright)=(65535,0,0)
    ModifyGraph mode(mdc_sep)=3, marker(mdc_sep)=19
    ModifyGraph mode(mdc_xleft)=3, marker(mdc_xleft)=19
    ModifyGraph mode(mdc_xright)=3, marker(mdc_xright)=19
    Label left "Sep"
    Label right "XLeft / XRight"
    Label bottom "index / delay"
    return 0
End

Function LJZ_MDCPeakSep_SelectCurrentRowIfValid(forceNoConfirm)
    Variable forceNoConfirm

    String base = LJZ_MDCPeakSep_BaseDF()
    Variable sel = NumVarOrDefault(base + ":SelRow", -1)
    if (sel < 0)
        return -1
    endif
    return LJZ_MDCPeakSep_SelectRow(sel, forceNoConfirm)
End


