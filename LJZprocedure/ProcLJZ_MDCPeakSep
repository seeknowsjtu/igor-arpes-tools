    NVAR/Z LeftX1 = $(base + ":LeftX1")
    NVAR/Z LeftX2 = $(base + ":LeftX2")
    NVAR/Z RightX1 = $(base + ":RightX1")
    NVAR/Z RightX2 = $(base + ":RightX2")
    if (!NVAR_Exists(LeftX1) || !NVAR_Exists(LeftX2) || !NVAR_Exists(RightX1) || !NVAR_Exists(RightX2))
        return -1
    endif
    LeftX1 = NaN
    LeftX2 = NaN
    RightX1 = NaN
    RightX2 = NaN
