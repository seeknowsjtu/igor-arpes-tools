Function LJZ_MDCPeakSep_WaveXMin(w)
    Wave w
    return DimOffset(w,0)
End

Function LJZ_MDCPeakSep_WaveXMax(w)
    Wave w
    return DimOffset(w,0) + DimDelta(w,0) * (numpnts(w)-1)
End

Function LJZ_MDCPeakSep_CountFiniteInWindow(w, x1, x2)
    Wave w
    Variable x1, x2

    Variable xa = min(x1, x2)
    Variable xb = max(x1, x2)
    Variable i, n = numpnts(w), c=0, xv
    for (i=0; i<n; i+=1)
        xv = pnt2x(w, i)
        if (xv >= xa && xv <= xb && numtype(w[i]) == 0)
            c += 1
        endif
    endfor
    return c
End

Function LJZ_MDCPeakSep_PeakCenter(w, x1, x2)
    Wave w
    Variable x1, x2

    Variable xa = min(x1, x2)
    Variable xb = max(x1, x2)
    Variable i, n = numpnts(w)
    Variable bestP = -1
    Variable bestY = NaN
    Variable xv, yv

    if (!LJZ_MDCPeakSep_Is1DWave(w))
        return NaN
    endif
    if (n < 3)
        return NaN
    endif
    if (numtype(xa) != 0 || numtype(xb) != 0 || xa == xb)
        return NaN
    endif

    for (i=0; i<n; i+=1)
        xv = pnt2x(w, i)
        if (xv < xa || xv > xb)
            continue
        endif
        yv = w[i]
        if (numtype(yv) != 0)
            continue
        endif
        if (bestP < 0 || yv > bestY)
            bestP = i
            bestY = yv
        endif
    endfor

    if (bestP < 0)
        return NaN
    endif

    // Prefer 3-point parabolic refinement if neighbors exist and are finite.
    if (bestP > 0 && bestP < n-1)
        Variable y1 = w[bestP-1]
        Variable y2 = w[bestP]
        Variable y3 = w[bestP+1]
        if (numtype(y1) == 0 && numtype(y2) == 0 && numtype(y3) == 0)
            Variable dx = DimDelta(w,0)
            if (numtype(dx) == 0 && dx != 0)
                Variable den = (y1 - 2*y2 + y3)
                if (abs(den) > 1e-20)
                    Variable delta = 0.5 * (y1 - y3) / den
                    if (abs(delta) <= 1)
                        Variable x0 = pnt2x(w, bestP)
                        return x0 + delta * dx
                    endif
                endif
            endif
        endif
    endif

    return pnt2x(w, bestP)
End

Function LJZ_MDCPeakSep_MeasureWaveByPath(wPath, showAlert)
    String wPath
    Variable showAlert

    String base = LJZ_MDCPeakSep_BaseDF()
    Wave/Z w = $wPath
    if (!LJZ_MDCPeakSep_Is1DWave(w))
        if (showAlert)
            DoAlert 0, "Selected wave is invalid or not 1D."
        endif
        return -1
    endif

    NVAR/Z LeftX1 = $(base + ":LeftX1")
    NVAR/Z LeftX2 = $(base + ":LeftX2")
    NVAR/Z RightX1 = $(base + ":RightX1")
    NVAR/Z RightX2 = $(base + ":RightX2")
    NVAR/Z XLeft = $(base + ":XLeft")
    NVAR/Z XRight = $(base + ":XRight")
    NVAR/Z Sep = $(base + ":Sep")
    if (!NVAR_Exists(LeftX1) || !NVAR_Exists(LeftX2) || !NVAR_Exists(RightX1) || !NVAR_Exists(RightX2) || !NVAR_Exists(XLeft) || !NVAR_Exists(XRight) || !NVAR_Exists(Sep))
        if (showAlert)
            DoAlert 0, "Measurement globals are missing. Please reopen the panel and try again."
        endif
        return -1
    endif

    Variable nLeft = LJZ_MDCPeakSep_CountFiniteInWindow(w, LeftX1, LeftX2)
    Variable nRight = LJZ_MDCPeakSep_CountFiniteInWindow(w, RightX1, RightX2)
    if (nLeft < 1 || nRight < 1)
        if (showAlert)
            DoAlert 0, "One or both peak windows contain no finite points."
        endif
        return -1
    endif

    Variable xL = LJZ_MDCPeakSep_PeakCenter(w, LeftX1, LeftX2)
    Variable xR = LJZ_MDCPeakSep_PeakCenter(w, RightX1, RightX2)
    if (numtype(xL) != 0 || numtype(xR) != 0)
        if (showAlert)
            DoAlert 0, "Peak center detection failed in one or both windows."
        endif
        return -1
    endif

    XLeft = xL
    XRight = xR
    Sep = xR - xL

    if (LJZ_MDCPeakSep_WriteResultForWave(wPath, XLeft, XRight, Sep) != 0)
        if (showAlert)
            DoAlert 0, "Failed to write result waves in source DF."
        endif
        return -1
    endif

    LJZ_MDCPeakSep_MarkDirty(0)
    return 0
End

Function LJZ_MDCPeakSep_MeasureCurrentWave(showAlert)
    Variable showAlert
    String base = LJZ_MDCPeakSep_BaseDF()
    SVAR/Z sWaveSel = $(base + ":WaveSel")
    if (!SVAR_Exists(sWaveSel) || strlen(sWaveSel) == 0)
        if (showAlert)
            DoAlert 0, "No MDC wave selected."
        endif
        return -1
    endif
    return LJZ_MDCPeakSep_MeasureWaveByPath(sWaveSel, showAlert)
End

Function LJZ_MDCPeakSep_MeasureAll()
    String base = LJZ_MDCPeakSep_BaseDF()
    SVAR/Z sSourceDF = $(base + ":SourceDF")
    if (!SVAR_Exists(sSourceDF))
        DoAlert 0, "Source DF is unavailable."
        return -1
    endif
    String wl = LJZ_MDCPeakSep_ListMDCShowWaves_OneDF(sSourceDF)
    Variable n = ItemsInList(wl, ";")
    Variable i, okCount=0, failCount=0, idx, maxIdx=-1

    if (n <= 0)
        DoAlert 0, "No mdc_show_* waves found in current Source DF."
        return -1
    endif

    for (i=0; i<n; i+=1)
        idx = LJZ_MDCPeakSep_ParseWaveIndex(NameOfWave($StringFromList(i, wl, ";")))
        if (numtype(idx) == 0)
            maxIdx = max(maxIdx, idx)
        endif
    endfor

    if (LJZ_MDCPeakSep_EnsureResultWaves(sSourceDF, maxIdx) != 0)
        DoAlert 0, "Failed to prepare result waves."
        return -1
    endif
    LJZ_MDCPeakSep_ClearResultWaves(sSourceDF)

    for (i=0; i<n; i+=1)
        String wp = StringFromList(i, wl, ";")
        if (LJZ_MDCPeakSep_MeasureWaveByPath(wp, 0) == 0)
            okCount += 1
        else
            failCount += 1
        endif
    endfor

    DoAlert 0, "Measure All finished. OK=" + num2str(okCount) + ", Failed=" + num2str(failCount)
    return 0
End

Function LJZ_MDCPeakSep_MeasureAndAdvance()
    String base = LJZ_MDCPeakSep_BaseDF()
    NVAR/Z SelRow = $(base + ":SelRow")
    Wave/T/Z wDisp = $(base + ":LB_Disp")
    if (!NVAR_Exists(SelRow) || !WaveExists(wDisp))
        return -1
    endif

    if (LJZ_MDCPeakSep_MeasureCurrentWave(1) != 0)
        return -1
    endif

    Variable nextRow = SelRow + 1
    if (nextRow >= 0 && nextRow < numpnts(wDisp))
        return LJZ_MDCPeakSep_SelectRow(nextRow, 0)
    endif
    return 0
End


