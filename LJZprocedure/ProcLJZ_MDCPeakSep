Function LJZ_MDCPeakSep_AutoFillLeftWindow()
    String base = LJZ_MDCPeakSep_BaseDF()
    SVAR/Z sWaveSel = $(base + ":WaveSel")
    if (!SVAR_Exists(sWaveSel))
        return -1
    endif
    Wave/Z w = $sWaveSel
    if (!LJZ_MDCPeakSep_Is1DWave(w))
        return -1
    endif

    NVAR/Z LeftX1 = $(base + ":LeftX1")
    NVAR/Z LeftX2 = $(base + ":LeftX2")
    if (!NVAR_Exists(LeftX1) || !NVAR_Exists(LeftX2))
        return -1
    endif

    Variable xMin = LJZ_MDCPeakSep_WaveXMin(w)
    Variable xMax = LJZ_MDCPeakSep_WaveXMax(w)
    Variable span = xMax - xMin

    LeftX1 = xMin + 0.15 * span
    LeftX2 = xMin + 0.40 * span
    return 0
End

Function LJZ_MDCPeakSep_AutoFillRightWindow()
    String base = LJZ_MDCPeakSep_BaseDF()
