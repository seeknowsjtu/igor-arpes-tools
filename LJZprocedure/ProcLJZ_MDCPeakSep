Function/S LJZ_MDCPeakSep_GetCurrentRunDF()
    String out = ""

    SVAR/Z sRun1 = root:ARPES_LJZ:MDCExtract:RunDF
    if (SVAR_Exists(sRun1))
        if (strlen(sRun1) > 0 && DataFolderExists(RemoveEnding(sRun1, ":")))
            out = LJZ_MDCPeakSep_df_with_colon(sRun1)
            return out
        endif
    endif

    SVAR/Z sRun2 = root:Packages:ARPES_LJZ:MDCWB:TargetDF
    if (SVAR_Exists(sRun2))
        if (strlen(sRun2) > 0 && DataFolderExists(RemoveEnding(sRun2, ":")))
            out = LJZ_MDCPeakSep_df_with_colon(sRun2)
            return out
        endif
    endif

    return ""
End

Function LJZ_MDCPeakSep_UseCurrentRunDF()
    LJZ_MDCPeakSep_EnsureDF()

    SVAR sSourceDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")
    String runDF = LJZ_MDCPeakSep_GetCurrentRunDF()

    if (strlen(runDF) == 0)
        DoAlert 0, "没有找到当前 MDCExtract 的有效 RunDF。"
        return -1
    endif

    sSourceDF = runDF
    LJZ_MDCPeakSep_RebuildWaveList()
    LJZ_MDCPeakSep_RefreshCurrentSelection()
    LJZ_MDCPeakSep_RefreshTitleBoxes()
    return 0
End


