Function LJZ_MDCPeakSep_IsTargetMDCWave(w)
    Wave/Z w
    if (!LJZ_MDCPeakSep_Is1DWave(w))
        return 0
    endif

    String nm = NameOfWave(w)
    if (StringMatch(nm, "mdc_show_*"))
        return 1
    endif
    return 0
End

Function LJZ_MDCPeakSep_ParseWaveIndex(wName)
    String wName
    Variable idx = NaN
    sscanf wName, "mdc_show_%d", idx
    return idx
End

Function/S LJZ_MDCPeakSep_ListMDCShowWaves_OneDF(df)
    String df

    String dfc = LJZ_MDCPeakSep_df_with_colon(df)
    String oldDF = GetDataFolder(1)
    SetDataFolder $dfc
    String wl = WaveList("mdc_show_*", ";", "DIMS:1")
    SetDataFolder $oldDF
    String out = ""
    Variable i, n = ItemsInList(wl, ";")
    Variable bestIdx, j

    if (n <= 0)
        return ""
    endif

    Make/FREE/N=(n) idxW = NaN
    Make/FREE/T/N=(n) nmW = ""
    for (i=0; i<n; i+=1)
        nmW[i] = StringFromList(i, wl, ";")
        idxW[i] = LJZ_MDCPeakSep_ParseWaveIndex(nmW[i])
    endfor

    // simple selection sort by parsed index; NaN at end
    for (i=0; i<n; i+=1)
        bestIdx = i
        for (j=i+1; j<n; j+=1)
            if (numtype(idxW[bestIdx]) != 0)
                bestIdx = j
            elseif (numtype(idxW[j]) == 0 && idxW[j] < idxW[bestIdx])
                bestIdx = j
            endif
        endfor
        if (bestIdx != i)
            Variable tmpV = idxW[i]
            String tmpS = nmW[i]
            idxW[i] = idxW[bestIdx]
            nmW[i] = nmW[bestIdx]
            idxW[bestIdx] = tmpV
            nmW[bestIdx] = tmpS
        endif
    endfor

    for (i=0; i<n; i+=1)
        if (strlen(nmW[i]) > 0)
            out += dfc + nmW[i] + ";"
        endif
    endfor

    return out
End

Function LJZ_MDCPeakSep_EnsureResultWaves(sourceDF, maxIdx)
    String sourceDF
    Variable maxIdx

    String dfc = LJZ_MDCPeakSep_df_with_colon(sourceDF)
    Variable n = max(maxIdx + 1, 0)
    Variable oldN
    if (n <= 0)
        return -1
    endif

    Wave/Z wL0 = $(dfc + "mdc_xleft")
    if (!WaveExists(wL0))
        Make/O/N=(n) $(dfc + "mdc_xleft") = NaN
    elseif (numpnts(wL0) < n)
        oldN = numpnts(wL0)
        Redimension/N=(n) wL0
        wL0[oldN, n-1] = NaN
    endif

    Wave/Z wR0 = $(dfc + "mdc_xright")
    if (!WaveExists(wR0))
        Make/O/N=(n) $(dfc + "mdc_xright") = NaN
    elseif (numpnts(wR0) < n)
        oldN = numpnts(wR0)
        Redimension/N=(n) wR0
        wR0[oldN, n-1] = NaN
    endif

    Wave/Z wS0 = $(dfc + "mdc_sep")
    if (!WaveExists(wS0))
        Make/O/N=(n) $(dfc + "mdc_sep") = NaN
    elseif (numpnts(wS0) < n)
        oldN = numpnts(wS0)
        Redimension/N=(n) wS0
        wS0[oldN, n-1] = NaN
    endif

    Wave/Z wL = $(dfc + "mdc_xleft")
    Wave/Z wR = $(dfc + "mdc_xright")
    Wave/Z wS = $(dfc + "mdc_sep")
    if (!WaveExists(wL) || !WaveExists(wR) || !WaveExists(wS))
        return -1
    endif

    String oldDF = GetDataFolder(1)
    SetDataFolder $dfc
    NVAR/Z run_t0 = Run_t0
    NVAR/Z run_dt = Run_dt
    if (NVAR_Exists(run_t0) && NVAR_Exists(run_dt) && numtype(run_t0) == 0 && numtype(run_dt) == 0)
        SetScale/P x, run_t0, run_dt, "", wL, wR, wS
    else
        SetScale/P x, 0, 1, "", wL, wR, wS
    endif

    SetDataFolder $oldDF
    return 0
End

Function LJZ_MDCPeakSep_ClearResultWaves(sourceDF)
    String sourceDF
    String dfc = LJZ_MDCPeakSep_df_with_colon(sourceDF)
    Wave/Z wL = $(dfc + "mdc_xleft")
    Wave/Z wR = $(dfc + "mdc_xright")
    Wave/Z wS = $(dfc + "mdc_sep")
    if (WaveExists(wL))
        wL = NaN
    endif
    if (WaveExists(wR))
        wR = NaN
    endif
    if (WaveExists(wS))
        wS = NaN
    endif
    return 0
End

Function LJZ_MDCPeakSep_WriteResultForWave(wPath, xLeftVal, xRightVal, sepVal)
    String wPath
    Variable xLeftVal, xRightVal, sepVal

    String nm = NameOfWave($wPath)
    Variable idx = LJZ_MDCPeakSep_ParseWaveIndex(nm)
    if (numtype(idx) != 0 || idx < 0)
        return -1
    endif

    String sourceDF = GetWavesDataFolder($wPath, 1)
    if (LJZ_MDCPeakSep_EnsureResultWaves(sourceDF, idx) != 0)
        return -1
    endif

    Wave/Z wL = $(sourceDF + "mdc_xleft")
    Wave/Z wR = $(sourceDF + "mdc_xright")
    Wave/Z wS = $(sourceDF + "mdc_sep")

    if (!WaveExists(wL) || !WaveExists(wR) || !WaveExists(wS))
        return -1
    endif
    if (idx >= numpnts(wL) || idx >= numpnts(wR) || idx >= numpnts(wS))
        return -1
    endif

    wL[idx] = xLeftVal
    wR[idx] = xRightVal
    wS[idx] = sepVal
    return 0
End

Function LJZ_MDCPeakSep_RebuildWaveList()
    LJZ_MDCPeakSep_EnsureDF()

    String base = LJZ_MDCPeakSep_BaseDF()
    SVAR/Z sSourceDF = $(base + ":SourceDF")
    SVAR/Z sWaveSel  = $(base + ":WaveSel")
    NVAR/Z SelRow    = $(base + ":SelRow")
    Wave/T/Z wDisp   = $(base + ":LB_Disp")
    Wave/Z wSel      = $(base + ":LB_Sel")
    if (!SVAR_Exists(sSourceDF) || !SVAR_Exists(sWaveSel) || !NVAR_Exists(SelRow) || !WaveExists(wDisp) || !WaveExists(wSel))
        return -1
    endif

    String wl = LJZ_MDCPeakSep_ListMDCShowWaves_OneDF(sSourceDF)
    Variable n = ItemsInList(wl, ";")

    Redimension/N=(n) wDisp, wSel
    wSel = 0

    Variable i
    for (i=0; i<n; i+=1)
        String wp = StringFromList(i, wl, ";")
        wDisp[i] = LJZ_MDCPeakSep_WaveShortLabel(wp)
    endfor

    if (n <= 0)
        SelRow = -1
        sWaveSel = ""
        LJZ_MDCPeakSep_ClearCurrentMeasure()
        LJZ_MDCPeakSep_ClearWindowGlobals()
        LJZ_MDCPeakSep_MarkDirty(0)
        return 0
    endif

    if (SelRow < 0 || SelRow >= n)
        SelRow = 0
    endif

    wSel[SelRow] = 1
    sWaveSel = StringFromList(SelRow, wl, ";")
    return 0
End


