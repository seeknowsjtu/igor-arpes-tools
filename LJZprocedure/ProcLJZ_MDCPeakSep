Function LJZ_MDCPeakSep_AutoFillWindows()
    LJZ_MDCPeakSep_EnsureDF()

    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    if (strlen(sWave) == 0)
        DoAlert 0, "请先选择一个 mdc_show_* 波形。"
        return -1
    endif

    Wave/Z w = $sWave
    if (!WaveExists(w) || !LJZ_MDCPeakSep_Is1DWave(w))
        DoAlert 0, "当前选择不是有效的 1D wave。"
        return -1
    endif

    Variable xA = pnt2x(w, 0)
    Variable xB = pnt2x(w, numpnts(w) - 1)
    Variable xMin = min(xA, xB)
    Variable xMax = max(xA, xB)
    Variable span = xMax - xMin

    if (span <= 0)
        return -1
    endif

    NVAR LeftX1 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX1")
    NVAR LeftX2 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX2")
    NVAR RightX1 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX1")
    NVAR RightX2 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX2")

    LeftX1 = xMin + 0.15 * span
    LeftX2 = xMin + 0.40 * span
    RightX1 = xMin + 0.60 * span
    RightX2 = xMin + 0.85 * span
    return 0
End

