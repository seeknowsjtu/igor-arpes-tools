Function LJZ_MDCPeakSep_ButtonProc(ctrlName) : ButtonControl
    String ctrlName

    strswitch(ctrlName)
        case "btnUseCurrent":
            if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
                return 0
            endif
            String curDF = LJZ_MDCPeakSep_GetCurrentRunDF()
            if (strlen(curDF) == 0)
                DoAlert 0, "No current RunDF/TargetDF found."
                return 0
            endif
            if (LJZ_MDCPeakSep_SetSourceDF(curDF) != 0)
                DoAlert 0, "Failed to use current DF."
                return 0
            endif
            LJZ_MDCPeakSep_RebuildWaveList()
            if (LJZ_MDCPeakSep_SelectCurrentRowIfValid(1) != 0)
                LJZ_MDCPeakSep_RefreshGraph()
                LJZ_MDCPeakSep_RefreshWindowControls()
                LJZ_MDCPeakSep_RefreshResultControls()
            endif
            break

        case "btnRefresh":
            if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
                return 0
            endif
            LJZ_MDCPeakSep_RebuildWaveList()
            if (LJZ_MDCPeakSep_SelectCurrentRowIfValid(1) != 0)
                LJZ_MDCPeakSep_RefreshGraph()
                LJZ_MDCPeakSep_RefreshWindowControls()
                LJZ_MDCPeakSep_RefreshResultControls()
            endif
            break

        case "btnAutoLeft":
            LJZ_MDCPeakSep_AutoFillLeftWindow()
            LJZ_MDCPeakSep_MarkDirty(1)
            LJZ_MDCPeakSep_RefreshWindowControls()
            LJZ_MDCPeakSep_RefreshGraph()
            break

        case "btnAutoRight":
            LJZ_MDCPeakSep_AutoFillRightWindow()
            LJZ_MDCPeakSep_MarkDirty(1)
            LJZ_MDCPeakSep_RefreshWindowControls()
            LJZ_MDCPeakSep_RefreshGraph()
            break

        case "btnMeasure":
            if (LJZ_MDCPeakSep_MeasureCurrentWave(1) == 0)
                LJZ_MDCPeakSep_RefreshResultControls()
                LJZ_MDCPeakSep_RefreshGraph()
            endif
            break

        case "btnMeasureNext":
            if (LJZ_MDCPeakSep_MeasureAndAdvance() == 0)
                LJZ_MDCPeakSep_RefreshResultControls()
                LJZ_MDCPeakSep_RefreshGraph()
            endif
            break

        case "btnMeasureAll":
            if (LJZ_MDCPeakSep_MeasureAll() == 0)
                LJZ_MDCPeakSep_LoadSavedResultForCurrentWave()
                LJZ_MDCPeakSep_RefreshResultControls()
                LJZ_MDCPeakSep_RefreshGraph()
            endif
            break

        case "btnPlot":
            LJZ_MDCPeakSep_PlotResult()
            break
    endswitch

    return 0
End

Function LJZ_MDCPeakSep_SetVarProc(ctrlName, varNum, varStr, varName) : SetVariableControl
    String ctrlName
    Variable varNum
    String varStr
    String varName

    strswitch(ctrlName)
        case "svSourceDF":
            if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
                SetVariable/Z svSourceDF, win=$(LJZ_MDCPeakSep_PanelName()), value=_STR:$(LJZ_MDCPeakSep_BaseDF()+":SourceDF")
                return 0
            endif
            if (LJZ_MDCPeakSep_SetSourceDF(varStr) != 0)
                DoAlert 0, "Invalid Source DF."
                SetVariable/Z svSourceDF, win=$(LJZ_MDCPeakSep_PanelName()), value=_STR:$(LJZ_MDCPeakSep_BaseDF()+":SourceDF")
                return 0
            endif
            LJZ_MDCPeakSep_RebuildWaveList()
            if (LJZ_MDCPeakSep_SelectCurrentRowIfValid(1) != 0)
                LJZ_MDCPeakSep_RefreshGraph()
                LJZ_MDCPeakSep_RefreshWindowControls()
                LJZ_MDCPeakSep_RefreshResultControls()
            endif
            break

        case "svLeftX1":
        case "svLeftX2":
        case "svRightX1":
        case "svRightX2":
            LJZ_MDCPeakSep_MarkDirty(1)
            LJZ_MDCPeakSep_RefreshWindowControls()
            LJZ_MDCPeakSep_RefreshGraph()
            break
    endswitch

    return 0
End

Function LJZ_MDCPeakSep_ListBoxProc(ctrlName, row, col, event) : ListBoxControl
    String ctrlName
    Variable row, col, event

    // eventCode 4 = selection changed
    if (event != 4)
        return 0
    endif

    if (cmpstr(ctrlName, "lbWave") != 0)
        return 0
    endif

    LJZ_MDCPeakSep_SelectRow(row, 0)
    return 0
End
