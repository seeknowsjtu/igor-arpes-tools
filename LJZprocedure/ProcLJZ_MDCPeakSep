    // Bottom info
    // ------------------------------------------------------------
    SetVariable svSelWave,pos={10,542},size={1035,20},title="Selected Wave:"
    SetVariable svSelWave,value=_STR:LJZ_MDCPeakSep_BaseDF() + ":WaveSel",noedit=1

    SetVariable svSrcDF,pos={10,566},size={1035,20},title="Source DF:"
    SetVariable svSrcDF,value=_STR:LJZ_MDCPeakSep_BaseDF() + ":SourceDF",noedit=1

    TitleBox tbMsg,pos={10,592},size={1035,18},frame=0,title="Definition: center = local peak maximum inside each window; refinement = 3-point parabola around the max"
    LJZ_MDCPeakSep_CreateGraphSubwindow()
    LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
    return 0
End

Function LJZ_MDCPeakSep_RefreshTitleBoxes()
    String p = LJZ_MDCPeakSep_PanelName()
    if (WinType(p) == 0)
        return 0
    endif

    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    SVAR sDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")

    SetVariable svSourceDF, win=$p, value=_STR:sDF
    SetVariable svSelWave, win=$p, value=_STR:sWave
    SetVariable svSrcDF, win=$p, value=_STR:sDF
    return 0
End


// ============================================================================
//  Section 6. callbacks
// ============================================================================

Function LJZ_MDCPeakSep_ButtonProc(ba) : ButtonControl
    STRUCT WMButtonAction &ba

    if (ba.eventCode != 2)
        return 0
    endif

    String ctrlName = ba.ctrlName

    if (CmpStr(ctrlName, "btUseCurrent") == 0)
        if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
            LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
            return 0
        endif
        LJZ_MDCPeakSep_UseCurrentRunDF()
        return 0
    endif

    if (CmpStr(ctrlName, "btScan") == 0)
        if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
            LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
            return 0
        endif
        LJZ_MDCPeakSep_RebuildWaveList()
        LJZ_MDCPeakSep_RefreshCurrentSelection()
        LJZ_MDCPeakSep_RefreshTitleBoxes()
        return 0
    endif

    if (CmpStr(ctrlName, "btRefresh") == 0)
        LJZ_MDCPeakSep_RefreshCurrentSelection()
        return 0
    endif

    if (CmpStr(ctrlName, "btAuto") == 0)
        LJZ_MDCPeakSep_AutoFillWindows()
        LJZ_MDCPeakSep_MarkDirty(1)
        LJZ_MDCPeakSep_UpdateGraphMarks()
        return 0
    endif

    if (CmpStr(ctrlName, "btAutoLeft") == 0)
        LJZ_MDCPeakSep_AutoFillLeftWindow()
        LJZ_MDCPeakSep_MarkDirty(1)
        LJZ_MDCPeakSep_UpdateGraphMarks()
        return 0
    endif

    if (CmpStr(ctrlName, "btAutoRight") == 0)
        LJZ_MDCPeakSep_AutoFillRightWindow()
        LJZ_MDCPeakSep_MarkDirty(1)
        LJZ_MDCPeakSep_UpdateGraphMarks()
        return 0
    endif

    if (CmpStr(ctrlName, "btMeasure") == 0)
        LJZ_MDCPeakSep_FindPeakSep()
        return 0
    endif

    if (CmpStr(ctrlName, "btMeasureAll") == 0)
        LJZ_MDCPeakSep_MeasureAll()
        return 0
    endif

    if (CmpStr(ctrlName, "btMeasureNext") == 0)
        LJZ_MDCPeakSep_MeasureAndNext()
        return 0
    endif

    if (CmpStr(ctrlName, "btPlotResult") == 0)
        LJZ_MDCPeakSep_PlotResult()
        return 0
    endif

    return 0
End

Function LJZ_MDCPeakSep_SetVarProc(sva) : SetVariableControl
    STRUCT WMSetVariableAction &sva

    if ((sva.eventCode != 1) && (sva.eventCode != 2))
        return 0
    endif

    String ctrlName = sva.ctrlName

    if (CmpStr(ctrlName, "svSourceDF") == 0)
        SVAR sDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")
        if (CmpStr(sDF, LJZ_MDCPeakSep_df_with_colon(sva.sval)) != 0)
            if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
                LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
                LJZ_MDCPeakSep_RefreshTitleBoxes()
                return 0
            endif
        endif
        sDF = LJZ_MDCPeakSep_df_with_colon(sva.sval)
        LJZ_MDCPeakSep_RebuildWaveList()
        LJZ_MDCPeakSep_RefreshCurrentSelection()
        LJZ_MDCPeakSep_RefreshTitleBoxes()
        return 0
    endif

    if ((CmpStr(ctrlName, "svLeftX1") == 0) || (CmpStr(ctrlName, "svLeftX2") == 0) || (CmpStr(ctrlName, "svRightX1") == 0) || (CmpStr(ctrlName, "svRightX2") == 0))
        LJZ_MDCPeakSep_MarkDirty(1)
        LJZ_MDCPeakSep_UpdateGraphMarks()
        return 0
    endif

    return 0
End

Function LJZ_MDCPeakSep_ListBoxProc(lba) : ListBoxControl
    STRUCT WMListboxAction &lba

    if ((lba.eventCode != 1) && (lba.eventCode != 4))
        return 0
    endif

    if (CmpStr(lba.ctrlName, "lbWave") == 0)
        if (lba.row >= 0)
            NVAR SelRow = $(LJZ_MDCPeakSep_BaseDF() + ":SelRow")
            if (lba.row != SelRow)
                if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
                    LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
                    return 0
                endif
            endif
            LJZ_MDCPeakSep_SelectWaveRow(lba.row)
            LJZ_MDCPeakSep_RefreshCurrentSelection()
            if (LJZ_MDCPeakSep_LoadStoredResultForSelection() != 0)
                LJZ_MDCPeakSep_ClearCurrentResultDisplay()
                LJZ_MDCPeakSep_AutoFillWindows()
                LJZ_MDCPeakSep_ShowCurrentWave()
            endif
            LJZ_MDCPeakSep_RefreshWindowControls()
            LJZ_MDCPeakSep_RefreshResultControls()
            LJZ_MDCPeakSep_RefreshTitleBoxes()
        endif
    endif

    return 0
End
