End

Function LJZ_RemoveAllTracesFromGraph(gPath)
    String gPath

    String trList, tr
    Variable i, n

    trList = TraceNameList(gPath, ";", 1)
    n = ItemsInList(trList, ";")
    for (i = n - 1; i >= 0; i -= 1)
        tr = StringFromList(i, trList, ";")
        if (strlen(tr) > 0)
            RemoveFromGraph/Z/W=$gPath $tr
        endif
    endfor
End

Function LJZ_MDCPeakSep_RefreshGraph()
    LJZ_MDCPeakSep_EnsureGraphWindow()

    String gPath = LJZ_MDCPeakSep_GraphPath()
    String base = LJZ_MDCPeakSep_BaseDF()
    SVAR/Z sWaveSel = $(base + ":WaveSel")
    Wave/Z stub = $(base + ":GraphStub")
    if (!SVAR_Exists(sWaveSel) || !WaveExists(stub))
        return -1
    endif
    Wave/Z w = $sWaveSel

    if (strlen(sWaveSel) == 0 || !LJZ_MDCPeakSep_Is1DWave(w))
        LJZ_RemoveAllTracesFromGraph(gPath)
        AppendToGraph/W=$gPath stub
        ModifyGraph/W=$gPath rgb(stub)=(45000,45000,45000)
        TextBox/C/N=tbInfo/W=$gPath/F=0/A=RT/X=0/Y=0 "No valid MDC selected"
        return 0
    endif

    LJZ_RemoveAllTracesFromGraph(gPath)
    AppendToGraph/W=$gPath w
    ModifyGraph/W=$gPath rgb($NameOfWave(w))=(0,0,0)

    NVAR/Z LeftX1 = $(base + ":LeftX1")
    NVAR/Z LeftX2 = $(base + ":LeftX2")
    NVAR/Z RightX1 = $(base + ":RightX1")
    NVAR/Z RightX2 = $(base + ":RightX2")
    NVAR/Z XLeft = $(base + ":XLeft")
    NVAR/Z XRight = $(base + ":XRight")
    NVAR/Z Sep = $(base + ":Sep")
    if (!NVAR_Exists(LeftX1) || !NVAR_Exists(LeftX2) || !NVAR_Exists(RightX1) || !NVAR_Exists(RightX2) || !NVAR_Exists(XLeft) || !NVAR_Exists(XRight) || !NVAR_Exists(Sep))
        LJZ_RemoveAllTracesFromGraph(gPath)
        AppendToGraph/W=$gPath stub
        ModifyGraph/W=$gPath rgb(stub)=(45000,45000,45000)
        TextBox/C/N=tbInfo/W=$gPath/F=0/A=RT/X=0/Y=0 "Measurement globals unavailable"
        return -1
    endif

    // remove old cursors / draw objects
    Cursor/K/W=$gPath A
    Cursor/K/W=$gPath B
    Cursor/K/W=$gPath C
    Cursor/K/W=$gPath D

    SetDrawLayer/W=$gPath UserFront
    DrawAction/W=$gPath delete

    Variable yMin, yMax
    WaveStats/Q w
    yMin = V_min
    yMax = V_max
    if (numtype(yMin) != 0 || numtype(yMax) != 0 || yMax <= yMin)
        yMin = 0
        yMax = 1
    endif

    if (numtype(LeftX1) == 0)
        SetDrawEnv/W=$gPath xcoord=bottom,ycoord=left, linefgc=(0,30000,60000), dash=3
        DrawLine/W=$gPath LeftX1, yMin, LeftX1, yMax
    endif
    if (numtype(LeftX2) == 0)
        SetDrawEnv/W=$gPath xcoord=bottom,ycoord=left, linefgc=(0,30000,60000), dash=3
        DrawLine/W=$gPath LeftX2, yMin, LeftX2, yMax
    endif
    if (numtype(RightX1) == 0)
        SetDrawEnv/W=$gPath xcoord=bottom,ycoord=left, linefgc=(50000,10000,10000), dash=3
        DrawLine/W=$gPath RightX1, yMin, RightX1, yMax
    endif
    if (numtype(RightX2) == 0)
        SetDrawEnv/W=$gPath xcoord=bottom,ycoord=left, linefgc=(50000,10000,10000), dash=3
        DrawLine/W=$gPath RightX2, yMin, RightX2, yMax
    endif

    if (numtype(XLeft) == 0)
        SetDrawEnv/W=$gPath xcoord=bottom,ycoord=left, linefgc=(0,0,65535), dash=0, linethick=2
        DrawLine/W=$gPath XLeft, yMin, XLeft, yMax
    endif
    if (numtype(XRight) == 0)
        SetDrawEnv/W=$gPath xcoord=bottom,ycoord=left, linefgc=(65535,0,0), dash=0, linethick=2
        DrawLine/W=$gPath XRight, yMin, XRight, yMax
    endif

    String info = "Wave: " + LJZ_MDCPeakSep_ShortenForTitle(LJZ_MDCPeakSep_WaveShortLabel(sWaveSel), 24) + "\r"
    info += "Left = " + SelectString(numtype(XLeft)==0, "--", num2str(XLeft)) + "\r"
    info += "Right = " + SelectString(numtype(XRight)==0, "--", num2str(XRight)) + "\r"
    info += "Sep = " + SelectString(numtype(Sep)==0, "--", num2str(Sep))
    TextBox/C/N=tbInfo/W=$gPath/F=0/A=RT/X=0/Y=0 info
    return 0
End

