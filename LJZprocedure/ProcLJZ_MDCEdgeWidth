Function LJZ_MDCPeakSep_RefreshTitleBoxes()
    String p = LJZ_MDCPeakSep_PanelName()
    if (WinType(p) == 0)
        return 0
    endif

    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    SVAR sDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")

    SetVariable svSourceDF, win=$p, value=_STR:sDF
    SetVariable svSelWave, win=$p, value=_STR:sWave
    SetVariable svSrcDF, win=$p, value=_STR:sDF
    return 0
End


