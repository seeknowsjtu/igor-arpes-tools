#pragma TextEncoding = "UTF-8"
#pragma rtGlobals=3
#pragma DefaultTab={3,20,4}

// ============================================================================
//  LJZ_MDCEdgeWidth : panel-inline MDC edge-width tool
//  只负责：
//    1) 从当前 RunDF / 手动指定 DF 扫描严格命名的 mdc_show_i
//    2) 在 panel 内联 graph 中显示当前选中的 mdc_show_i
//    3) 在两个 x-window 内分别寻找 rising / falling edge position
//    4) 把 XRise / XFall / Width 写回 SourceDF 下的结果 wave
//
//  不负责：
//    - 3D 提取
//    - smoothing
//    - fit
// ============================================================================

Menu "ARPES_LJZ"
    "2026MDCEdgeWidth_LJZ", LJZ_MDCPeakSep()
End


// ============================================================================
//  Section 0. paths / state
// ============================================================================

Function/S LJZ_MDCPeakSep_BaseDF()
    return "root:ARPES_LJZ:MDCEdgeWidth"
End

Function/S LJZ_MDCPeakSep_PanelName()
    return "LJZ_MDCEdgeWidth_Panel"
End

Function/S LJZ_MDCPeakSep_GraphName()
    return "mdcGraph"
End

Function/S LJZ_MDCPeakSep_GraphPath()
    return LJZ_MDCPeakSep_PanelName() + "#" + LJZ_MDCPeakSep_GraphName()
End

Function/S LJZ_MDCPeakSep_df_with_colon(inStr)
    String inStr
    String s = inStr

    if (strlen(s) == 0)
        return "root:"
    endif

    if (StringMatch(s, "root"))
        s = "root:"
    endif

    if (!StringMatch(s, "*:"))
        s += ":"
    endif

    return s
End

Function LJZ_MDCPeakSep_df_exists(dfStr)
    String dfStr
    String s = LJZ_MDCPeakSep_df_with_colon(dfStr)
    return DataFolderExists(s)
End

Function LJZ_MDCPeakSep_Is1DWave(w)
    Wave/Z w

    if (!WaveExists(w))
        return 0
    endif
    if (DimSize(w, 0) <= 0)
        return 0
    endif
    if (DimSize(w, 1) > 0 || DimSize(w, 2) > 0 || DimSize(w, 3) > 0)
        return 0
    endif

    return 1
End

Function/S LJZ_MDCPeakSep_WaveNameFromPath(wPath)
    String wPath

    Variable n = ItemsInList(wPath, ":")
    if (n <= 0)
        return wPath
    endif

    return StringFromList(n - 1, wPath, ":")
End

Function/S LJZ_MDCPeakSep_WaveShortLabel(wPath)
    String wPath

    String nm = NameOfWave($wPath)
    if (strlen(nm) == 0)
        nm = LJZ_MDCPeakSep_WaveNameFromPath(wPath)
    endif
    if (strlen(nm) == 0)
        nm = wPath
    endif

    return nm
End

Function LJZ_MDCPeakSep_Clamp(v, lo, hi)
    Variable v, lo, hi

    if (v < lo)
        return lo
    endif
    if (v > hi)
        return hi
    endif
    return v
End

Function LJZ_MDCPeakSep_SanitizeEdgeFrac(v)
    Variable v

    if (numtype(v) != 0)
        return 0.5
    endif
    return LJZ_MDCPeakSep_Clamp(v, 0, 1)
End

Function LJZ_MDCPeakSep_HasChildSubwindow(hostWin, childName)
    String hostWin, childName

    String childList = ChildWindowList(hostWin)
    return (WhichListItem(childName, childList, ";", 0, 0) >= 0)
End

Function LJZ_MDCPeakSep_EnsureDF()
    NewDataFolder/O root:ARPES_LJZ
    NewDataFolder/O $(LJZ_MDCPeakSep_BaseDF())

    SVAR/Z sSourceDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")
    if (!SVAR_Exists(sSourceDF))
        String/G $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF") = "root:"
    endif

    SVAR/Z sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    if (!SVAR_Exists(sWave))
        String/G $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel") = ""
    endif

    NVAR/Z SelRow = $(LJZ_MDCPeakSep_BaseDF() + ":SelRow")
    if (!NVAR_Exists(SelRow))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":SelRow") = -1
    endif

    NVAR/Z LeftX1 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX1")
    if (!NVAR_Exists(LeftX1))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":LeftX1") = NaN
    endif

    NVAR/Z LeftX2 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX2")
    if (!NVAR_Exists(LeftX2))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":LeftX2") = NaN
    endif

    NVAR/Z RightX1 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX1")
    if (!NVAR_Exists(RightX1))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":RightX1") = NaN
    endif

    NVAR/Z RightX2 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX2")
    if (!NVAR_Exists(RightX2))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":RightX2") = NaN
    endif

    NVAR/Z EdgeFrac = $(LJZ_MDCPeakSep_BaseDF() + ":EdgeFrac")
    if (!NVAR_Exists(EdgeFrac))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":EdgeFrac") = 0.5
    endif

    NVAR/Z XRise = $(LJZ_MDCPeakSep_BaseDF() + ":XRise")
    if (!NVAR_Exists(XRise))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":XRise") = NaN
    endif

    NVAR/Z XFall = $(LJZ_MDCPeakSep_BaseDF() + ":XFall")
    if (!NVAR_Exists(XFall))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":XFall") = NaN
    endif

    NVAR/Z Width = $(LJZ_MDCPeakSep_BaseDF() + ":Width")
    if (!NVAR_Exists(Width))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":Width") = NaN
    endif

    NVAR/Z Dirty = $(LJZ_MDCPeakSep_BaseDF() + ":Dirty")
    if (!NVAR_Exists(Dirty))
        Variable/G $(LJZ_MDCPeakSep_BaseDF() + ":Dirty") = 0
    endif

    Wave/T/Z wDisp = $(LJZ_MDCPeakSep_BaseDF() + ":LB_Disp")
    if (!WaveExists(wDisp))
        Make/O/T/N=0 $(LJZ_MDCPeakSep_BaseDF() + ":LB_Disp")
    endif

    Wave/Z wSel = $(LJZ_MDCPeakSep_BaseDF() + ":LB_Sel")
    if (!WaveExists(wSel))
        Make/O/N=0 $(LJZ_MDCPeakSep_BaseDF() + ":LB_Sel") = 0
    endif

    Make/O/N=2 $(LJZ_MDCPeakSep_BaseDF() + ":GraphStub") = NaN
    SetScale/P x, 0, 1, "", $(LJZ_MDCPeakSep_BaseDF() + ":GraphStub")

    return 0
End

Function LJZ_MDCPeakSep_MarkDirty(flag)
    Variable flag

    NVAR Dirty = $(LJZ_MDCPeakSep_BaseDF() + ":Dirty")
    Dirty = (flag != 0)
    return 0
End

Function LJZ_MDCPeakSep_IsDirty()
    NVAR Dirty = $(LJZ_MDCPeakSep_BaseDF() + ":Dirty")
    return Dirty
End

Function LJZ_MDCPeakSep_ClearWindowGlobals()
    NVAR LeftX1 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX1")
    NVAR LeftX2 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX2")
    NVAR RightX1 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX1")
    NVAR RightX2 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX2")

    LeftX1 = NaN
    LeftX2 = NaN
    RightX1 = NaN
    RightX2 = NaN
    return 0
End

Function LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
    LJZ_MDCPeakSep_EnsureDF()

    String panelName = LJZ_MDCPeakSep_PanelName()
    NVAR SelRow = $(LJZ_MDCPeakSep_BaseDF() + ":SelRow")
    Wave/Z wSel = $(LJZ_MDCPeakSep_BaseDF() + ":LB_Sel")
    if (!WaveExists(wSel))
        return 0
    endif

    wSel = 0
    if (SelRow >= 0 && SelRow < numpnts(wSel))
        wSel[SelRow] = 1
        ListBox/Z lbWave, win=$panelName, selRow=SelRow
    else
        ListBox/Z lbWave, win=$panelName, selRow=-1
    endif

    ControlUpdate/W=$panelName lbWave
    return 0
End

Function LJZ_MDCPeakSep_ConfirmLeaveIfDirty()
    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    if (strlen(sWave) == 0)
        return 1
    endif

    if (!LJZ_MDCPeakSep_IsDirty())
        return 1
    endif

    DoAlert 1, "Current edge-width windows have unmeasured edits. Discard them and continue?"
    if (V_flag == 1)
        LJZ_MDCPeakSep_MarkDirty(0)
        return 1
    endif

    return 0
End


