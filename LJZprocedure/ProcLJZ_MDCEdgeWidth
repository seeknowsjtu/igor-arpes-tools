//  Section 2. scan mdc_show_* / result waves
// ============================================================================

Function LJZ_MDCPeakSep_IsTargetMDCWave(w, nm)
    Wave/Z w
    String nm

    if (!LJZ_MDCPeakSep_Is1DWave(w))
        return 0
    endif
    if (numtype(LJZ_MDCPeakSep_ParseWaveIndex(nm)) != 0)
        return 0
    endif

    return 1
End

Function LJZ_MDCPeakSep_ParseWaveIndex(nm)
    String nm

    Variable idx = NaN
    String exact = ""

    sscanf nm, "mdc_show_%d", idx
    if (V_flag != 1)
        return NaN
    endif
    if (numtype(idx) != 0 || idx < 0)
        return NaN
    endif

    sprintf exact, "mdc_show_%d", idx
    if (CmpStr(nm, exact) != 0)
        return NaN
    endif

    return idx
End

Function/S LJZ_MDCPeakSep_InsertWavePathSorted(pathIn, listIn)
    String pathIn, listIn

    String out = listIn
    String nmIn = LJZ_MDCPeakSep_WaveNameFromPath(pathIn)
    Variable idxIn = LJZ_MDCPeakSep_ParseWaveIndex(nmIn)
    Variable n = ItemsInList(out, ";")
    Variable i

    if (n <= 0)
        return AddListItem(pathIn, "", ";", 0)
    endif

    for (i = 0; i < n; i += 1)
        String pathCur = StringFromList(i, out, ";")
        String nmCur = LJZ_MDCPeakSep_WaveNameFromPath(pathCur)
        Variable idxCur = LJZ_MDCPeakSep_ParseWaveIndex(nmCur)
        if (numtype(idxCur) != 0 || idxIn < idxCur)
            return AddListItem(pathIn, out, ";", i)
        endif
    endfor

    return AddListItem(pathIn, out, ";", Inf)
End

Function/S LJZ_MDCPeakSep_ListMDCShowWaves_OneDF(dfStr)
    String dfStr

    String dfc = LJZ_MDCPeakSep_df_with_colon(dfStr)
    String out = ""
    Variable iObj, nObj

    if (!DataFolderExists(dfc))
        return ""
    endif

    nObj = CountObjects(dfc, 1)
    for (iObj = 0; iObj < nObj; iObj += 1)
        String nm = GetIndexedObjName(dfc, 1, iObj)
        Wave/Z w = $(dfc + nm)
        if (!WaveExists(w))
            continue
        endif
        if (!LJZ_MDCPeakSep_IsTargetMDCWave(w, nm))
            continue
        endif
        out = LJZ_MDCPeakSep_InsertWavePathSorted(dfc + nm, out)
    endfor

    return out
End

Function/S LJZ_MDCPeakSep_CurrentWaveList()
    SVAR sDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")
    return LJZ_MDCPeakSep_ListMDCShowWaves_OneDF(LJZ_MDCPeakSep_df_with_colon(sDF))
End

Function LJZ_MDCPeakSep_MaxWaveIndexInList(listStr)
    String listStr

    Variable maxIdx = -1
    Variable n = ItemsInList(listStr, ";")
    Variable i

    for (i = 0; i < n; i += 1)
        String wPath = StringFromList(i, listStr, ";")
        Variable idx = LJZ_MDCPeakSep_ParseWaveIndex(LJZ_MDCPeakSep_WaveNameFromPath(wPath))
        if (numtype(idx) == 0)
            maxIdx = max(maxIdx, idx)
        endif
    endfor

    return maxIdx
End

Function LJZ_MDCPeakSep_ResultWaveShouldUseRunScale(dfStr)
    String dfStr

    String srcDF = LJZ_MDCPeakSep_df_with_colon(dfStr)
    String curRun = LJZ_MDCPeakSep_GetCurrentRunDF()
    if (CmpStr(srcDF, curRun) != 0)
        return 0
    endif

    NVAR/Z Run_t0 = root:ARPES_LJZ:MDCExtract:Run_t0
    NVAR/Z Run_dt = root:ARPES_LJZ:MDCExtract:Run_dt
    if (!NVAR_Exists(Run_t0) || !NVAR_Exists(Run_dt))
        return 0
    endif
    if (numtype(Run_t0) != 0 || numtype(Run_dt) != 0)
        return 0
    endif

    return 1
End

Function LJZ_MDCPeakSep_ApplyResultWaveScale(w, dfStr)
    Wave w
    String dfStr

    if (LJZ_MDCPeakSep_ResultWaveShouldUseRunScale(dfStr))
        NVAR Run_t0 = root:ARPES_LJZ:MDCExtract:Run_t0
        NVAR Run_dt = root:ARPES_LJZ:MDCExtract:Run_dt
        SetScale/P x, Run_t0, Run_dt, "", w
    else
        SetScale/P x, 0, 1, "", w
    endif

    return 0
End

Function LJZ_MDCPeakSep_EnsureResultWaves()
    LJZ_MDCPeakSep_EnsureDF()

    SVAR sDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")
    String dfStr = LJZ_MDCPeakSep_df_with_colon(sDF)
    String listStr = LJZ_MDCPeakSep_ListMDCShowWaves_OneDF(dfStr)
    Variable maxIdx = LJZ_MDCPeakSep_MaxWaveIndexInList(listStr)
    Variable nResult = maxIdx + 1

    if (!DataFolderExists(dfStr))
        return -1
    endif

    if (nResult < 0)
        nResult = 0
    endif

    Wave/Z wRise = $(dfStr + "mdc_xrise")
    if (!WaveExists(wRise))
        Make/O/N=(nResult) $(dfStr + "mdc_xrise") = NaN
    else
        Variable oldRiseN = numpnts(wRise)
        if (oldRiseN != nResult)
            Redimension/N=(nResult) wRise
            if (nResult > oldRiseN)
                wRise[oldRiseN, nResult - 1] = NaN
            endif
        endif
    endif

    Wave/Z wFall = $(dfStr + "mdc_xfall")
    if (!WaveExists(wFall))
        Make/O/N=(nResult) $(dfStr + "mdc_xfall") = NaN
    else
        Variable oldFallN = numpnts(wFall)
        if (oldFallN != nResult)
            Redimension/N=(nResult) wFall
            if (nResult > oldFallN)
                wFall[oldFallN, nResult - 1] = NaN
            endif
        endif
    endif

    Wave/Z wWidth = $(dfStr + "mdc_width")
    if (!WaveExists(wWidth))
        Make/O/N=(nResult) $(dfStr + "mdc_width") = NaN
    else
        Variable oldWidthN = numpnts(wWidth)
        if (oldWidthN != nResult)
            Redimension/N=(nResult) wWidth
            if (nResult > oldWidthN)
                wWidth[oldWidthN, nResult - 1] = NaN
            endif
        endif
    endif

    Wave wRise2 = $(dfStr + "mdc_xrise")
    Wave wFall2 = $(dfStr + "mdc_xfall")
    Wave wWidth2 = $(dfStr + "mdc_width")
    LJZ_MDCPeakSep_ApplyResultWaveScale(wRise2, dfStr)
    LJZ_MDCPeakSep_ApplyResultWaveScale(wFall2, dfStr)
    LJZ_MDCPeakSep_ApplyResultWaveScale(wWidth2, dfStr)

    return 0
End

Function LJZ_MDCPeakSep_ClearResultWaves()
    LJZ_MDCPeakSep_EnsureDF()

    SVAR sDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")
    String dfStr = LJZ_MDCPeakSep_df_with_colon(sDF)

    Wave/Z wRise = $(dfStr + "mdc_xrise")
    Wave/Z wFall = $(dfStr + "mdc_xfall")
    Wave/Z wWidth = $(dfStr + "mdc_width")

    if (WaveExists(wRise))
        wRise = NaN
    endif
    if (WaveExists(wFall))
        wFall = NaN
    endif
    if (WaveExists(wWidth))
        wWidth = NaN
    endif

    return 0
End

Function LJZ_MDCPeakSep_WriteResultForWave(wPath, xRiseVal, xFallVal, widthVal)
    String wPath
    Variable xRiseVal, xFallVal, widthVal

    SVAR sDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")
    String dfStr = LJZ_MDCPeakSep_df_with_colon(sDF)
    String nm = NameOfWave($wPath)
    Variable idx

    if (strlen(nm) == 0)
        nm = LJZ_MDCPeakSep_WaveNameFromPath(wPath)
    endif
    idx = LJZ_MDCPeakSep_ParseWaveIndex(nm)
    if (numtype(idx) != 0)
        return -1
    endif

    LJZ_MDCPeakSep_EnsureResultWaves()

    Wave/Z wRise = $(dfStr + "mdc_xrise")
    Wave/Z wFall = $(dfStr + "mdc_xfall")
    Wave/Z wWidth = $(dfStr + "mdc_width")
    if (!WaveExists(wRise) || !WaveExists(wFall) || !WaveExists(wWidth))
        return -1
    endif
    if (idx < 0 || idx >= numpnts(wRise) || idx >= numpnts(wFall) || idx >= numpnts(wWidth))
        return -1
    endif

    wRise[idx] = xRiseVal
    wFall[idx] = xFallVal
    wWidth[idx] = widthVal
    return 0
End

Function LJZ_MDCPeakSep_RebuildWaveList()
    LJZ_MDCPeakSep_EnsureDF()

    SVAR sDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")
    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    NVAR SelRow = $(LJZ_MDCPeakSep_BaseDF() + ":SelRow")

    String dfStr = LJZ_MDCPeakSep_df_with_colon(sDF)
    if (!DataFolderExists(dfStr))
        Make/O/T/N=0 $(LJZ_MDCPeakSep_BaseDF() + ":LB_Disp")
        Make/O/N=0 $(LJZ_MDCPeakSep_BaseDF() + ":LB_Sel")
        sWave = ""
        SelRow = -1
        LJZ_MDCPeakSep_ClearWindowGlobals()
        LJZ_MDCPeakSep_ClearCurrentResultDisplay()
        return -1
    endif

    String prevWave = sWave
    String listStr = LJZ_MDCPeakSep_ListMDCShowWaves_OneDF(dfStr)
    Variable n = ItemsInList(listStr, ";")

    Make/O/T/N=(n) $(LJZ_MDCPeakSep_BaseDF() + ":LB_Disp")
    Make/O/N=(n) $(LJZ_MDCPeakSep_BaseDF() + ":LB_Sel") = 0

    Wave/T wDisp = $(LJZ_MDCPeakSep_BaseDF() + ":LB_Disp")
    Wave wSel = $(LJZ_MDCPeakSep_BaseDF() + ":LB_Sel")

    Variable i
    String wPath
    for (i = 0; i < n; i += 1)
        wPath = StringFromList(i, listStr, ";")
        wDisp[i] = LJZ_MDCPeakSep_WaveShortLabel(wPath)
    endfor

    Variable keepRow = WhichListItem(prevWave, listStr, ";", 0, 0)
    if (keepRow < 0)
        keepRow = 0
    endif

    if (n > 0)
        keepRow = LJZ_MDCPeakSep_Clamp(keepRow, 0, n - 1)
        wSel[keepRow] = 1
        sWave = StringFromList(keepRow, listStr, ";")
        SelRow = keepRow
    else
        sWave = ""
        SelRow = -1
        LJZ_MDCPeakSep_ClearWindowGlobals()
        LJZ_MDCPeakSep_ClearCurrentResultDisplay()
    endif

    LJZ_MDCPeakSep_EnsureResultWaves()
    LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
    return 0
End

Function LJZ_MDCPeakSep_SelectWaveRow(row)
    Variable row

    LJZ_MDCPeakSep_EnsureDF()

    String listStr = LJZ_MDCPeakSep_CurrentWaveList()
    Variable n = ItemsInList(listStr, ";")
    if (n <= 0)
        return -1
    endif

    row = max(0, min(n - 1, row))

    Wave wSel = $(LJZ_MDCPeakSep_BaseDF() + ":LB_Sel")
    if (numpnts(wSel) != n)
        Redimension/N=(n) wSel
    endif
    wSel = 0
    wSel[row] = 1

    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    NVAR SelRow = $(LJZ_MDCPeakSep_BaseDF() + ":SelRow")
    sWave = StringFromList(row, listStr, ";")
    SelRow = row
    return 0
End

Function LJZ_MDCPeakSep_CurrentWaveResultIndex()
    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    if (strlen(sWave) == 0)
        return NaN
    endif

    return LJZ_MDCPeakSep_ParseWaveIndex(LJZ_MDCPeakSep_WaveNameFromPath(sWave))
End

Function LJZ_MDCPeakSep_ClearCurrentResultDisplay()
    NVAR XRise = $(LJZ_MDCPeakSep_BaseDF() + ":XRise")
    NVAR XFall = $(LJZ_MDCPeakSep_BaseDF() + ":XFall")
    NVAR Width = $(LJZ_MDCPeakSep_BaseDF() + ":Width")

    XRise = NaN
    XFall = NaN
    Width = NaN

    String panelName = LJZ_MDCPeakSep_PanelName()
    String graphName = LJZ_MDCPeakSep_GraphName()
    String graphPath = LJZ_MDCPeakSep_GraphPath()
    if (LJZ_MDCPeakSep_HasChildSubwindow(panelName, graphName))
        TextBox/W=$graphPath/K/N=tbEdge
        SetDrawLayer/W=$graphPath UserFront
        DrawAction/W=$graphPath getgroup=EdgeMarks, delete
    endif

    return 0
End

Function LJZ_MDCPeakSep_LoadStoredResultForSelection()
    LJZ_MDCPeakSep_ClearCurrentResultDisplay()

    SVAR sDF = $(LJZ_MDCPeakSep_BaseDF() + ":SourceDF")
    Variable idx = LJZ_MDCPeakSep_CurrentWaveResultIndex()
    if (numtype(idx) != 0)
        return -1
    endif

    String dfStr = LJZ_MDCPeakSep_df_with_colon(sDF)
    Wave/Z wRise = $(dfStr + "mdc_xrise")
    Wave/Z wFall = $(dfStr + "mdc_xfall")
    Wave/Z wWidth = $(dfStr + "mdc_width")
    if (!WaveExists(wRise) || !WaveExists(wFall) || !WaveExists(wWidth))
        return -1
    endif
    if (idx < 0 || idx >= numpnts(wRise) || idx >= numpnts(wFall) || idx >= numpnts(wWidth))
        return -1
    endif

    NVAR XRise = $(LJZ_MDCPeakSep_BaseDF() + ":XRise")
    NVAR XFall = $(LJZ_MDCPeakSep_BaseDF() + ":XFall")
    NVAR Width = $(LJZ_MDCPeakSep_BaseDF() + ":Width")

    XRise = wRise[idx]
    XFall = wFall[idx]
    Width = wWidth[idx]
    if (numtype(XRise) != 0 || numtype(XFall) != 0 || numtype(Width) != 0)
        LJZ_MDCPeakSep_ClearCurrentResultDisplay()
        return -1
    endif

    return 0
End


