Function LJZ_MDCPeakSep_MeasureWaveByPath(wPath, doAlertOnFail)
    String wPath
    Variable doAlertOnFail

    Wave/Z w = $wPath
    if (!WaveExists(w) || !LJZ_MDCPeakSep_Is1DWave(w))
        LJZ_MDCPeakSep_ClearCurrentResultDisplay()
        LJZ_MDCPeakSep_WriteResultForWave(wPath, NaN, NaN, NaN)
        return -1
    endif

    NVAR LeftX1 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX1")
    NVAR LeftX2 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX2")
    NVAR RightX1 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX1")
    NVAR RightX2 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX2")
    NVAR EdgeFrac = $(LJZ_MDCPeakSep_BaseDF() + ":EdgeFrac")
    EdgeFrac = LJZ_MDCPeakSep_SanitizeEdgeFrac(EdgeFrac)
    NVAR XRise = $(LJZ_MDCPeakSep_BaseDF() + ":XRise")
    NVAR XFall = $(LJZ_MDCPeakSep_BaseDF() + ":XFall")
    NVAR Width = $(LJZ_MDCPeakSep_BaseDF() + ":Width")

    Variable xRiseVal = LJZ_MDCPeakSep_EdgeCrossing(w, LeftX1, LeftX2, EdgeFrac, 1)
    Variable xFallVal = LJZ_MDCPeakSep_EdgeCrossing(w, RightX1, RightX2, EdgeFrac, 0)
    Variable widthVal = NaN

    if (numtype(xRiseVal) == 0 && numtype(xFallVal) == 0)
        widthVal = xFallVal - xRiseVal
        XRise = xRiseVal
        XFall = xFallVal
        Width = widthVal
        LJZ_MDCPeakSep_WriteResultForWave(wPath, xRiseVal, xFallVal, widthVal)
        return 0
    endif

    XRise = NaN
    XFall = NaN
    Width = NaN
    LJZ_MDCPeakSep_WriteResultForWave(wPath, NaN, NaN, NaN)

    if (doAlertOnFail)
        DoAlert 0, "在指定窗口内没有找到合法的 rising / falling edge crossing，请调整两个搜索范围。"
    endif

    return -1
End

Function LJZ_MDCPeakSep_FindWidth()
    LJZ_MDCPeakSep_EnsureDF()
    LJZ_MDCPeakSep_SyncEditableControlsFromPanel()

    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    if (strlen(sWave) == 0)
        DoAlert 0, "请先选择一个 mdc_show_* 波形。"
        return -1
    endif

    Variable ret = LJZ_MDCPeakSep_MeasureWaveByPath(sWave, 1)
    if (ret == 0)
        LJZ_MDCPeakSep_MarkDirty(0)
    endif
    LJZ_MDCPeakSep_RefreshWindowControls()
    LJZ_MDCPeakSep_RefreshResultControls()
    LJZ_MDCPeakSep_ShowCurrentWave()
    LJZ_MDCPeakSep_RefreshTitleBoxes()
    return ret
End

Function LJZ_MDCPeakSep_MeasureAll()
    LJZ_MDCPeakSep_EnsureDF()

    String listStr = LJZ_MDCPeakSep_CurrentWaveList()
    Variable n = ItemsInList(listStr, ";")
    if (n <= 0)
        DoAlert 0, "当前 SourceDF 下没有严格命名的 mdc_show_i 波形可测量。"
        return -1
    endif

    LJZ_MDCPeakSep_EnsureResultWaves()
    LJZ_MDCPeakSep_ClearResultWaves()

    Variable i
    for (i = 0; i < n; i += 1)
        String wPath = StringFromList(i, listStr, ";")
        LJZ_MDCPeakSep_MeasureWaveByPath(wPath, 0)
    endfor

    LJZ_MDCPeakSep_LoadStoredResultForSelection()
    LJZ_MDCPeakSep_MarkDirty(0)
    LJZ_MDCPeakSep_ShowCurrentWave()
    LJZ_MDCPeakSep_RefreshTitleBoxes()
    return 0
End

Function LJZ_MDCPeakSep_RefreshCurrentSelection()
    if (LJZ_MDCPeakSep_IsDirty())
        LJZ_MDCPeakSep_SyncEditableControlsFromPanel()
        LJZ_MDCPeakSep_RefreshWindowControls()
        LJZ_MDCPeakSep_RefreshResultControls()
        LJZ_MDCPeakSep_ShowCurrentWave()
        return 0
    endif

    if (LJZ_MDCPeakSep_LoadStoredResultForSelection() == 0)
        LJZ_MDCPeakSep_ShowCurrentWave()
    else
        LJZ_MDCPeakSep_ClearCurrentResultDisplay()

        SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
        Wave/Z w = $sWave
        if (strlen(sWave) > 0 && WaveExists(w) && LJZ_MDCPeakSep_Is1DWave(w))
            LJZ_MDCPeakSep_AutoFillWindows()
        endif

        LJZ_MDCPeakSep_RefreshWindowControls()
        LJZ_MDCPeakSep_ShowCurrentWave()
    endif

    LJZ_MDCPeakSep_RefreshWindowControls()
    LJZ_MDCPeakSep_RefreshResultControls()
    return 0
End

Function LJZ_MDCPeakSep_SelectRow(row, forceNoConfirm)
    Variable row, forceNoConfirm

    if (!forceNoConfirm)
        if (!LJZ_MDCPeakSep_ConfirmLeaveIfDirty())
            LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
            return -1
        endif
    endif

    String listStr = LJZ_MDCPeakSep_CurrentWaveList()
    Variable n = ItemsInList(listStr, ";")
    if (n <= 0)
        SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
        NVAR SelRow = $(LJZ_MDCPeakSep_BaseDF() + ":SelRow")
        sWave = ""
        SelRow = -1
        LJZ_MDCPeakSep_ClearWindowGlobals()
        LJZ_MDCPeakSep_ClearCurrentResultDisplay()
        LJZ_MDCPeakSep_RefreshWindowControls()
        LJZ_MDCPeakSep_RefreshResultControls()
        LJZ_MDCPeakSep_ShowCurrentWave()
        LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
        return -1
    endif

    if (row < 0 || row >= n)
        LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
        return -1
    endif

    LJZ_MDCPeakSep_SelectWaveRow(row)
    if (LJZ_MDCPeakSep_LoadStoredResultForSelection() != 0)
        LJZ_MDCPeakSep_ClearCurrentResultDisplay()
        LJZ_MDCPeakSep_AutoFillWindows()
    endif
    LJZ_MDCPeakSep_MarkDirty(0)

    LJZ_MDCPeakSep_RefreshWindowControls()
    LJZ_MDCPeakSep_RefreshResultControls()
    LJZ_MDCPeakSep_ShowCurrentWave()
    LJZ_MDCPeakSep_RestoreCurrentSelectionUI()
    return 0
End

Function LJZ_MDCPeakSep_MeasureAndNext()
    LJZ_MDCPeakSep_EnsureDF()

    Variable ret = LJZ_MDCPeakSep_FindWidth()
    String listStr = LJZ_MDCPeakSep_CurrentWaveList()
    Variable n = ItemsInList(listStr, ";")
    NVAR SelRow = $(LJZ_MDCPeakSep_BaseDF() + ":SelRow")

    if (ret == 0 && n > 0)
        if (SelRow < n - 1)
            LJZ_MDCPeakSep_MarkDirty(0)
            LJZ_MDCPeakSep_SelectWaveRow(SelRow + 1)
            LJZ_MDCPeakSep_RefreshCurrentSelection()
            LJZ_MDCPeakSep_RefreshTitleBoxes()
        endif
    endif

    return 0
End

