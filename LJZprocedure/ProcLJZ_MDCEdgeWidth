Function LJZ_MDCPeakSep_CreateGraphSubwindow()
    LJZ_MDCPeakSep_EnsureDF()

    String panelName = LJZ_MDCPeakSep_PanelName()
    String graphName = LJZ_MDCPeakSep_GraphName()
    String graphPath = LJZ_MDCPeakSep_GraphPath()
    if (WinType(panelName) == 0)
        return -1
    endif

    if (LJZ_MDCPeakSep_HasChildSubwindow(panelName, graphName))
        KillWindow/Z $graphPath
    endif

    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
    Wave/Z w = $sWave
    if (!WaveExists(w) || !LJZ_MDCPeakSep_Is1DWave(w))
        Wave stub = $(LJZ_MDCPeakSep_BaseDF() + ":GraphStub")
        Display/HOST=$panelName/N=$graphName/W=(250,40,960,360) stub
        ModifyGraph/W=$graphPath margin(left)=48,margin(bottom)=32,margin(right)=16,margin(top)=12,mirror=2
        Label/W=$graphPath left "Intensity (a.u.)"
        Label/W=$graphPath bottom "k"
        return 0
    endif

    Display/HOST=$panelName/N=$graphName/W=(250,40,960,360) w
    ModifyGraph/W=$graphPath margin(left)=48,margin(bottom)=32,margin(right)=16,margin(top)=12,mirror=2
    Label/W=$graphPath left "Intensity (a.u.)"
    Label/W=$graphPath bottom "k"
    return 0
End

Function LJZ_MDCPeakSep_UpdateGraphMarks()
    LJZ_MDCPeakSep_EnsureDF()

    String panelName = LJZ_MDCPeakSep_PanelName()
    String graphName = LJZ_MDCPeakSep_GraphName()
    String graphPath = LJZ_MDCPeakSep_GraphPath()
    if (!LJZ_MDCPeakSep_HasChildSubwindow(panelName, graphName))
        return 0
    endif

    NVAR XRise = $(LJZ_MDCPeakSep_BaseDF() + ":XRise")
    NVAR XFall = $(LJZ_MDCPeakSep_BaseDF() + ":XFall")
    NVAR Width = $(LJZ_MDCPeakSep_BaseDF() + ":Width")
    NVAR LeftX1 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX1")
    NVAR LeftX2 = $(LJZ_MDCPeakSep_BaseDF() + ":LeftX2")
    NVAR RightX1 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX1")
    NVAR RightX2 = $(LJZ_MDCPeakSep_BaseDF() + ":RightX2")

    String tb = ""
    if (numtype(XRise) == 0)
        tb += "XRise = " + num2str(XRise) + "\r"
    endif
    if (numtype(XFall) == 0)
        tb += "XFall = " + num2str(XFall) + "\r"
    endif
    if (numtype(Width) == 0)
        tb += "Width = " + num2str(Width)
    endif

    TextBox/W=$graphPath/K/N=tbEdge
    if (strlen(tb) > 0)
        TextBox/W=$graphPath/C/N=tbEdge/F=0/A=RT tb
    endif

    SetDrawLayer/W=$graphPath UserFront
    DrawAction/W=$graphPath getgroup=EdgeMarks, delete
    SetDrawEnv/W=$graphPath gstart, gname=EdgeMarks

    // edge window 边界：浅色细虚线。
    if (numtype(LeftX1) == 0)
        SetDrawEnv/W=$graphPath xcoord=bottom,ycoord=prel,linefgc=(45000,45000,65535),linethick=1,dash=1
        DrawLine/W=$graphPath LeftX1, 0, LeftX1, 1
    endif
    if (numtype(LeftX2) == 0)
        SetDrawEnv/W=$graphPath xcoord=bottom,ycoord=prel,linefgc=(45000,45000,65535),linethick=1,dash=1
        DrawLine/W=$graphPath LeftX2, 0, LeftX2, 1
    endif
    if (numtype(RightX1) == 0)
        SetDrawEnv/W=$graphPath xcoord=bottom,ycoord=prel,linefgc=(65535,45000,45000),linethick=1,dash=1
        DrawLine/W=$graphPath RightX1, 0, RightX1, 1
    endif
    if (numtype(RightX2) == 0)
        SetDrawEnv/W=$graphPath xcoord=bottom,ycoord=prel,linefgc=(65535,45000,45000),linethick=1,dash=1
        DrawLine/W=$graphPath RightX2, 0, RightX2, 1
    endif

    // 最终边沿位置：深色粗线。
    if (numtype(XRise) == 0)
        SetDrawEnv/W=$graphPath xcoord=bottom,ycoord=prel,linefgc=(0,0,65535),linethick=2,dash=2
        DrawLine/W=$graphPath XRise, 0, XRise, 1
    endif
    if (numtype(XFall) == 0)
        SetDrawEnv/W=$graphPath xcoord=bottom,ycoord=prel,linefgc=(65535,0,0),linethick=2,dash=2
        DrawLine/W=$graphPath XFall, 0, XFall, 1
    endif

    SetDrawEnv/W=$graphPath gstop
    return 0
End

Function LJZ_MDCPeakSep_ShowCurrentWave()
    LJZ_MDCPeakSep_EnsureDF()

    SVAR sWave = $(LJZ_MDCPeakSep_BaseDF() + ":WaveSel")
