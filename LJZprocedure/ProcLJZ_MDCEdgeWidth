    SetVariable svRightX2,pos={810,438},size={125,20},title="Fall x2"
    SetVariable svRightX2,variable=$(LJZ_MDCPeakSep_BaseDF() + ":RightX2"),proc=LJZ_MDCPeakSep_SetVarProc

    Button btAutoRight,pos={940,436},size={90,24},title="Auto Fall",proc=LJZ_MDCPeakSep_ButtonProc

    // ------------------------------------------------------------
    // Row 3 : measurement result
