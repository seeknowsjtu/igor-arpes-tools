Function LJZ_MDCPeakSep_WaveXMin(w)
    Wave w
    return DimOffset(w, 0)
End

Function LJZ_MDCPeakSep_WaveXMax(w)
    Wave w
    return DimOffset(w, 0) + DimDelta(w, 0) * (numpnts(w) - 1)
End

Function LJZ_MDCPeakSep_EdgeCrossing(w, x1, x2, frac, isRising)
    Wave w
    Variable x1, x2, frac, isRising

    Variable n = numpnts(w)
    if (n < 2)
        return NaN
    endif
    if (numtype(frac) != 0)
        return NaN
    endif

    Variable p1 = round(x2pnt(w, x1))
    Variable p2 = round(x2pnt(w, x2))
    if (numtype(p1) != 0 || numtype(p2) != 0)
        return NaN
    endif

    p1 = LJZ_MDCPeakSep_Clamp(p1, 0, n - 1)
    p2 = LJZ_MDCPeakSep_Clamp(p2, 0, n - 1)

    Variable pLo = min(p1, p2)
    Variable pHi = max(p1, p2)
    if (pHi - pLo < 1)
        return NaN
    endif

    Variable yMin = Inf
    Variable yMax = -Inf
    Variable p
    Variable finiteCount = 0

    for (p = pLo; p <= pHi; p += 1)
        Variable yv = w[p]
        if (numtype(yv) != 0)
            continue
        endif
        yMin = min(yMin, yv)
        yMax = max(yMax, yv)
        finiteCount += 1
    endfor

    if (finiteCount < 2)
        return NaN
    endif
    if (numtype(yMin) != 0 || numtype(yMax) != 0 || yMax <= yMin)
        return NaN
    endif

    frac = LJZ_MDCPeakSep_Clamp(frac, 0, 1)
    Variable yTarget = yMin + frac * (yMax - yMin)

    for (p = pLo; p < pHi; p += 1)
        Variable xA = pnt2x(w, p)
        Variable xB = pnt2x(w, p + 1)
        Variable yA = w[p]
        Variable yB = w[p + 1]

        if (numtype(xA) != 0 || numtype(xB) != 0 || numtype(yA) != 0 || numtype(yB) != 0)
            continue
        endif
        if (xA == xB || yA == yB)
            continue
        endif

        if (isRising)
            if (!(yA <= yTarget && yB >= yTarget && yB > yA))
                continue
            endif
        else
            if (!(yA >= yTarget && yB <= yTarget && yB < yA))
                continue
            endif
        endif

        Variable mix = (yTarget - yA) / (yB - yA)
        if (mix < 0 || mix > 1)
            continue
        endif

        return xA + mix * (xB - xA)
    endfor

    return NaN
End


